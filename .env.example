# Public environment variables for the Combac landing page
# These variables are exposed to the browser (prefix with PUBLIC_)

# App Store URL (e.g. https://apps.apple.com/app/your-app-id)
PUBLIC_APP_STORE_URL=

# Google Play Store URL (e.g. https://play.google.com/store/apps/details?id=com.example.app)
PUBLIC_GOOGLE_PLAY_URL=
